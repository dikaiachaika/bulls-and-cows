<h1>Игра #<%= game_display_number(@game) %></h1>

<div class="game-info">
  <p>Попыток: <%= @game.attempts.count %> / 10</p>
  
  <% if @game.status == 'active' %>
    <p>Статус: <span style="color: #28a745;">Активна</span></p>
  <% elsif @game.status == 'won' %>
    <div style="background-color: #d4edda; padding: 15px; border-radius: 5px; color: #155724;">
      <p>Победа! Вы угадали число!</p>
    </div>
  <% else %>
    <div style="background-color: #f8d7da; padding: 15px; border-radius: 5px; color: #721c24;">
      <p>Игра окончена. Загаданное число: <strong><%= @game.secret_number %></strong></p>
    </div>
  <% end %>
</div>

<% if @game.status == 'active' %>
  <div class="attempt-form">
    <h3>Введите ваш вариант:</h3>
    
    <%= form_with(url: attempt_game_path(@game), local: true) do |form| %>
      <div class="form-group">
       
        <%= form.text_field :guess, 
            maxlength: 4, 
            size: 4,
            placeholder: "1234",
            style: "width: 100px; text-align: center; font-size: 18px;",
            autocomplete: 'off',
            inputmode: 'numeric',
            pattern: '\d*' %>
        <small style="display: block; color: #666; margin-top: 5px;">Введите 4 разные цифры (например: 1234)</small>
      </div>
      
      <div class="form-group">
        <%= form.submit "Проверить", class: "btn", disabled: @game.max_attempts_reached? %>
      </div>
    <% end %>
  </div>
<% end %>

<h3>История попыток</h3>

<% if @game.attempts.any? %>
  <table>
    <thead>
      <tr>
        <th>Попытка</th>
        <th>Число</th>
        <th>Быки</th>
        <th>Коровы</th>
      </tr>
    </thead>
    <tbody>
      <% @game.attempts.order(created_at: :asc).each_with_index do |attempt, index| %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= attempt.guess %></td>
          <td class="bulls"><%= attempt.bulls %></td>
          <td class="cows"><%= attempt.cows %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Пока нет попыток</p>
<% end %>

<div class="button-group">
  <%= button_to "Новая игра", games_path, method: :post, class: "btn-new-game" %>
  <%= link_to "К списку игр", games_path, class: "btn-list" %>
  <%= button_to "Удалить игру", game_path(@game), method: :delete, 
      data: { confirm: "Вы уверены, что хотите удалить эту игру?" },
      class: "btn-delete" %>
</div>