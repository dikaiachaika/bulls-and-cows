<h1>Игра #<%= @game.id %></h1>

<div class="game-info">
  <p>Попыток: <%= @game.attempts.count %> / 10</p>
  
  <% if @game.status == 'active' %>
    <p>Статус: Активна</p>
  <% elsif @game.status == 'won' %>
    <div class="game-status won">
      <p>Победа! Вы угадали число!</p>
    </div>
  <% else %>
    <div class="game-status lost">
      <p>Игра окончена. Загаданное число: <strong><%= @game.secret_number %></strong></p>
    </div>
  <% end %>
</div>

<% if @game.status == 'active' %>
  <div class="attempt-form" data-controller="game">
    <h3>Введите ваш вариант:</h3>
    
    <%= form_with(url: attempt_game_path(@game), local: true) do |form| %>
      <div class="form-group">
        <%= form.label :guess, "4 цифры" %>
        <%= form.text_field :guess, 
            data: { game_target: "input" },
            maxlength: 4, 
            size: 4,
            placeholder: "1234",
            style: "width: 100px; text-align: center; font-size: 18px;",
            autocomplete: 'off',
            inputmode: 'numeric',
            pattern: '\d*' %>
        <small style="display: block; color: #666; margin-top: 5px;">Введите 4 цифры (например: 1234)</small>
      </div>
      
      <div class="form-group">
        <%= form.submit "Проверить", class: "btn", disabled: @game.max_attempts_reached? %>
      </div>
    <% end %>
  </div>
<% end %>

<h3>История попыток</h3>

<% if @game.attempts.any? %>
  <table>
    <thead>
      <tr>
        <th>Попытка</th>
        <th>Число</th>
        <th>Быки</th>
        <th>Коровы</th>
      </tr>
    </thead>
    <tbody>
      <% @game.attempts.order(created_at: :asc).each_with_index do |attempt, index| %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= attempt.guess %></td>
          <td class="bulls"><%= attempt.bulls %></td>
          <td class="cows"><%= attempt.cows %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Пока нет попыток</p>
<% end %>

<div style="margin-top: 20px;">
  <%= link_to "Новая игра", new_game_path, class: "btn btn-new" %>
  <%= link_to "К списку игр", games_path, class: "btn" %>
</div>