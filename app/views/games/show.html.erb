<h1>Игра #<%= game_display_number(@game) %></h1>
<div class="game-info-center">
  <div class="game-info-grid">
    <div class="grid-item">
      <strong>Статус:</strong>
      <% if @game.status == 'active' %>
        <span class="status-active">Активна</span>
      <% elsif @game.status == 'won' %>
        <span class="status-won">Победа</span>
      <% else %>
        <span class="status-lost">Поражение</span>
      <% end %>
    </div>
    <div class="grid-item">
      <strong>Длина числа:</strong>
      <%= @game.digit_length %> цифры
    </div>
    <div class="grid-item">
      <strong>Попыток:</strong>
      <%= @game.attempts.count %> / 10
    </div>
    <div class="grid-item">
      <strong>Время:</strong>
      <span id="timer"><%= @game.formatted_time %></span>
    </div>
  </div>
</div>
<% if @game.status == 'active' %>
  <div class="attempt-form">
    <h3>Введите ваш вариант:</h3>
    <%= form_with(
      url: attempt_game_path(@game),
      local: true,
      html: { id: 'guess-form' }
    ) do |form| %>
      <div class="form-group">
        <% phrase = digit_phrase(@game.digit_length) %>
        <%= form.label :guess, "#{@game.digit_length} #{phrase[:word]} (без повторений)" %>
        <%= form.text_field :guess,
          maxlength: (@game.digit_length || 4),
          placeholder: "_ " * (@game.digit_length || 4),
          class: "guess-input",
          autocomplete: 'off',
          inputmode: 'numeric',
          pattern: '\d*',
          data: {
            controller: "game",
            game_target: "input",
            action: "input->game#validateInput"} %>
        <small>
          Введите <%= @game.digit_length %> <%= phrase[:different] %> <%= phrase[:word] %>
          (например: <%= (0..9).to_a.sample(@game.safe_digit_length).join %>)
        </small>
      </div>
      <div class="form-group">
        <%= form.submit "Проверить",
            class: "btn submit-wide",
            disabled: @game.max_attempts_reached? %>
      </div>
    <% end %>
  </div>
<% end %>
<h3>История попыток</h3>
<% if @game.attempts.any? %>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>№</th>
          <th>Число</th>
          <th>Быки</th>
          <th>Коровы</th>
        </tr>
      </thead>
      <tbody>
        <% @game.attempts
             .order(created_at: :asc)
             .each_with_index do |attempt, index| %>
          <tr>
            <td><%= index + 1 %></td>
            <td class="guess-value">
              <%= attempt.guess %>
            </td>
            <td class="bulls">
              <%= attempt.bulls %>
            </td>
            <td class="cows">
              <%= attempt.cows %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="empty-attempts">
    Пока нет попыток
  </p>
<% end %>
<div class="button-group buttons-center">
  <%= button_to "Новая игра",
      games_path,
      method: :post,
      class: "btn btn-new" %>
  <%= link_to "К списку игр",
      games_path,
      class: "btn back-btn" %>
  <%= button_to "Удалить игру",
      @game,
      method: :delete,
      data: { confirm: "Удалить эту игру?" },
      class: "btn btn-danger" %>
</div>
<% if @game.status == 'active' && @game.started_at.present? %>
  <%= raw "
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const startTime = #{@game.started_at.to_i};
      const timerElement = document.getElementById('timer');
      if (!timerElement) return;
      function updateTimer() {
        const now = Math.floor(Date.now() / 1000);
        const elapsed = now - startTime;
        const minutes = Math.floor(elapsed / 60);
        const seconds = elapsed % 60;
        timerElement.textContent =
          `${minutes.toString().padStart(2,'0')}:${seconds.toString().padStart(2,'0')}`;
      }
      updateTimer();
      const timerInterval = setInterval(updateTimer, 1000);
      const checkGameStatus = setInterval(function() {
        if (
          document.querySelector('.game-status.won') ||
          document.querySelector('.game-status.lost')
        ) {
          clearInterval(timerInterval);
          clearInterval(checkGameStatus);
        }
      }, 1000);
    });
  </script>
  " %>
<% end %>