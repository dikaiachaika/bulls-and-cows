<h1>Игра #<%= game_display_number(@game) %></h1>

<div class="game-info">
  <p><strong>Попыток:</strong> <%= @game.attempts.count %> / 10</p>
  
  <% if @game.status == 'active' %>
    <p><strong>Статус:</strong> <span style="color: #28a745;">Активна</span></p>
  <% elsif @game.status == 'won' %>
    <div class="game-status won">
      <p>Победа! Вы угадали число!</p>
    </div>
  <% else %>
    <div class="game-status lost">
      <p>Игра окончена. Загаданное число: <strong><%= @game.secret_number %></strong></p>
    </div>
  <% end %>
</div>

<% if @game.status == 'active' %>
  <div class="attempt-form">
    <h3>Введите ваш вариант:</h3>
    
    <%= form_with(url: attempt_game_path(@game), local: true) do |form| %>
      <div class="form-group">
        <%= form.label :guess, "4 цифры (без повторений)" %>
        <%= form.text_field :guess, 
            maxlength: 4, 
            placeholder: "1234",
            style: "width: 100%; max-width: 200px; text-align: center; font-size: 18px; padding: 12px;",
            autocomplete: 'off',
            inputmode: 'numeric',
            pattern: '\d*' %>
        <small>Введите 4 разные цифры (например: 1234)</small>
      </div>
      
      <div class="form-group">
        <%= form.submit "Проверить", class: "btn", style: "width: 100%; max-width: 200px;", disabled: @game.max_attempts_reached? %>
      </div>
    <% end %>
  </div>
<% end %>

<h3>История попыток</h3>

<% if @game.attempts.any? %>
  <div style="overflow-x: auto;">
    <table>
      <thead>
        <tr>
          <th>№</th>
          <th>Число</th>
          <th>Быки</th>
          <th>Коровы</th>
        </tr>
      </thead>
      <tbody>
        <% @game.attempts.order(created_at: :asc).each_with_index do |attempt, index| %>
          <tr>
            <td><%= index + 1 %></td>
            <td style="font-weight: 600;"><%= attempt.guess %></td>
            <td class="bulls"><%= attempt.bulls %></td>
            <td class="cows"><%= attempt.cows %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p style="text-align: center; padding: 20px; background: #f8f9fa; border-radius: 8px;">Пока нет попыток</p>
<% end %>

<div class="button-group" style="justify-content: center;">
  <%= button_to "Новая игра", games_path, method: :post, class: "btn btn-new" %>
  <%= link_to "К списку игр", games_path, class: "btn", 
    style: "padding: 8px 24px; font-size: 16px; min-width: 100px; text-align: center; line-height: 1.5; font-weight: 450; font-family: inherit;" %>
  <%= button_to "Удалить игру", @game, method: :delete, 
      data: { confirm: "Удалить эту игру?" },
      class: "btn btn-danger" %>
</div>