<h1>Быки и коровы</h1>

<div class="game-info">
  <p>Правила игры:</p>
  <ul>
    <li>Компьютер загадывает 4-значное число</li>
    <li>Вы вводите свой вариант</li>
    <li>Быки - цифра на своем месте</li>
    <li>Коровы - цифра есть, но не на своем месте</li>
    <li>У вас есть 10 попыток</li>
  </ul>
</div>

<div style="text-align: center; margin: 30px 0;">
  <%= button_to "Новая игра", games_path, method: :post, class: "btn btn-new", style: "padding: 12px 30px; border: none; cursor: pointer; background-color: #28a745; color: white; border-radius: 4px; font-size: 16px;" %>
</div>

<h2>Последние игры</h2>

<table>
  <thead>
    <tr>
      <th>Дата</th>
      <th>Статус</th>
      <th>Попыток</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @games.each do |game| %>
      <tr>
        <td><%= game.created_at.strftime("%d.%m.%Y %H:%M") %></td>
        <td>
          <% if game.status == 'active' %>
            Активна
          <% elsif game.status == 'won' %>
            Победа
          <% else %>
            Поражение
          <% end %>
        </td>
        <td><%= game.attempts.count %></td>
        <td><%= link_to "Продолжить", game %></td>
      </tr>
    <% end %>
  </tbody>
</table>