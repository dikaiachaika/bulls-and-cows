<div class="top-bar">
  <% if current_user %>
    <div class="user-greeting">
      Привет, <%= current_user.name %>!
    </div>
    <div class="set-log-btn-group">
      <%= button_to "⚙ Настройки", edit_user_path(current_user), method: :get, class: "settings-btn" %>
      <%= button_to "Выйти", logout_path, method: :delete, class: "logout-btn" %>
    </div>
  <% end %>
</div>
<div class="game-header">
  <img src="<%= asset_path('bull.png') %>" alt="Бык">
  <h1 class="title-no-margin">Быки и коровы</h1>
  <img src="<%= asset_path('cow.png') %>" alt="Корова" class="cow-icon">
</div>
<div class="game-info">
  <p><strong>Правила игры:</strong></p>
  <ul class="rules-list">
    <li>Компьютер загадывает число с неповторяющимися цифрами</li>
    <li>Вы вводите свой вариант</li>
    <li>Быки - цифра на своем месте</li>
    <li>Коровы - цифра есть, но не на своем месте</li>
    <li>У Вас есть 10 попыток</li>
    <li>Ведется учет времени игры</li>
  </ul>
</div>
<div class="form-group center-form">
  <label for="digit_length">Выберите длину числа:</label>
  <%= form_with(url: games_path, method: :post, local: true, class: "inline-form") do |form| %>
    <div class="form-row">
      <%= form.select :digit_length,
          options_for_select([
            ['3 цифры', 3],
            ['4 цифры', 4],
            ['5 цифр', 5],
            ['6 цифр', 6]
          ], 4),
          {},
          class: "form-select" %>
      <%= form.submit "Новая игра", class: "btn btn-new new-game-btn" %>
    </div>
  <% end %>
</div>
<% if @games.any? %>
  <div class="tabs">
  <button class="tab-btn active" onclick="showSection('games', this)">
    🎮 Мои игры
  </button>
  <button class="tab-btn" onclick="showSection('stats', this)">
    📊 Статистика
  </button>
  <button class="tab-btn" onclick="showSection('records', this)">
    🏆 Рекорды игроков
  </button>
  </div>

  <div id="games-section">
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>Дата</th>
          <th>Статус</th>
          <th>Длина</th>
          <th>Попыток</th>
          <th>Время</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
        <% @games.each do |game| %>
          <tr>
            <td>
              <%= game.created_at.strftime("%d.%m %H:%M") %>
            </td>
            <td>
              <% if game.status == 'active' %>
                <span class="status-active">Активна</span>
              <% elsif game.status == 'won' %>
                <span class="status-won">Победа</span>
              <% else %>
                <span class="status-lost">Поражение</span>
              <% end %>
            </td>
            <td>
              <%= game.digit_length %>
            </td>
            <td>
              <%= game.attempts.count %>/10
            </td>
            <td>
              <%= game.formatted_time %>
            </td>
            <td>
              <div class="actions">
                <%= link_to "Играть",
                    game,
                    class: "play-btn" %>
                <%= button_to "✕",
                    game,
                    method: :delete,
                    data: { confirm: "Удалить?" },
                    class: "delete-btn" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  </div>

  <div id="stats-section" style="display:none;">
  <% if @stats.present? && @stats[:total_games] > 0 %>
    <div class="stats-container">
      <div class="stats-overview">
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-value"><%= @stats[:total_games] %></div>
            <div class="stat-label">Всего игр</div>
          </div>
          <div class="stat-card won">
            <div class="stat-value"><%= @stats[:games_won] %></div>
            <div class="stat-label">Побед</div>
          </div>
          <div class="stat-card lost">
            <div class="stat-value"><%= @stats[:games_lost] %></div>
            <div class="stat-label">Поражений</div>
          </div>
          <div class="stat-card active">
            <div class="stat-value"><%= @stats[:games_active] %></div>
            <div class="stat-label">Активных</div>
          </div>
        </div>
      </div>

      <div class="stats-details">
        <div class="detail-row">
          <span class="detail-label">Процент побед:</span>
          <span class="detail-value"><%= @stats[:win_rate] %>%</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Всего попыток:</span>
          <span class="detail-value"><%= @stats[:total_attempts] %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Среднее попыток за игру:</span>
          <span class="detail-value"><%= @stats[:avg_attempts_per_game] %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Лучшее время:</span>
          <span class="detail-value"><%= @stats[:best_time] %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Лучший результат (попыток):</span>
          <span class="detail-value"><%= @stats[:best_attempts] %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Общее время в игре:</span>
          <span class="detail-value"><%= format_seconds(@stats[:total_time_spent]) %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Последняя игра:</span>
          <span class="detail-value"><%= @stats[:last_game_date] %></span>
        </div>
      </div>

      <% if @stats[:by_digit_length].present? %>
        <div class="stats-by-length">
          <h4>Количество игр по длине числа</h4>
          <div class="length-grid">
            <% @stats[:by_digit_length].each do |length, count| %>
              <div class="length-card">
                <div class="length-value"><%= length %> цифры:</div>
                <div class="length-count"><%= count %></div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="empty-games">Нет данных для статистики. Сыграйте хотя бы одну игру!</p>
  <% end %>
  </div>

  <div id="records-section" style="display:none;">
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>Игрок</th>
          <th>Длина</th>
          <th>Попыток</th>
          <th>Время</th>
        </tr>
      </thead>
      <tbody>
        <% @records.each_with_index do |game, index| %>
          <tr>
            <td>
              <% if index == 0 %>🥇
              <% elsif index == 1 %>🥈
              <% elsif index == 2 %>🥉
              <% end %>
              <%= game.user.name %>
            </td>
            <td><%= game.digit_length %></td>
            <td><%= game.attempts.count %>/10</td>
            <td><%= game.formatted_time %></td>        
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  </div>

  <div class="games-count">
    <small>Всего игр: <%= @games.count %></small>
  </div>
<% else %>
  <p class="empty-games">
    Нет игр. Начните новую игру!
  </p>
<% end %>