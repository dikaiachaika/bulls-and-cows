<h1>Регистрация</h1>

<div class="game-info">
  <%= form_with model: @user do |f| %>
    <div class="form-group">
      <%= f.label :name, "Имя" %>
      <%= f.text_field :name, maxlength: 20, class: "guess-input", placeholder: "Введите имя" %>
    </div>

    <div class="form-group">
      <%= f.label :password, "Пароль" %>
      <%= f.password_field :password, maxlength: 20, class: "guess-input", placeholder: "Введите пароль" %>
      <small>Пароль не может быть меньше 6 символов</small>
    </div>

    <div class="form-group">
      <%= f.label :password_confirmation, "Подтвердите пароль" %>
      <%= f.password_field :password_confirmation, maxlength: 20, class: "guess-input" %>
    </div>

    <div class="center-form">
      <%= f.submit "Зарегистрироваться", class: "btn btn-new new-game-btn" %>
    </div>
  <% end %>
</div>