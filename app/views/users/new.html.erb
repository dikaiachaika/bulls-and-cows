<h1>Регистрация</h1>

<div class="game-info">
  <%= form_with model: @user do |f| %>
    <div class="form-group">
      <%= f.label :name, "Имя" %>
      <%= f.text_field :name, maxlength: 20, class: "guess-input", placeholder: "Введите имя" %>
    </div>

    <div class="form-group">
      <%= f.label :password, "Пароль" %>
      <%= f.password_field :password, maxlength: 20, class: "guess-input", id: "password-field", placeholder: "Введите пароль" %>
    </div>

    <div class="form-group">
      <%= f.label :password_confirmation, "Подтвердить пароль" %>
      <%= f.password_field :password_confirmation, maxlength: 20, class: "guess-input", placeholder: "Повторите пароль" %>
    </div>

    <div class="form-group">
      <%= f.label :security_question, "Секретный вопрос" %>
      <%= f.text_field :security_question, maxlength: 200, class: "guess-input", placeholder: adaptive_placeholder %>
    </div>

    <div class="form-group">
      <%= f.label :security_answer, "Ответ" %>
      <%= f.text_field :security_answer, maxlength: 150, class: "guess-input", placeholder: "Введите ответ на секретный вопрос" %>
    </div>

    <div class="center-form">
      <%= f.submit "Зарегистрироваться", class: "btn btn-new new-game-btn" %>
    </div>
  <% end %>
</div>