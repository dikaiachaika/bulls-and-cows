<h1>Вход</h1>

<div class="game-info">
  <%= form_with url: login_path do |f| %>
    <div class="form-group">
      <%= label_tag :name, "Имя" %>
      <%= text_field_tag :name, nil, maxlength: 20, class: "guess-input", placeholder: "Введите имя" %>
    </div>

    <div class="form-group">
      <%= label_tag :password, "Пароль" %>
      <%= password_field_tag :password, nil, maxlength: 20, class: "guess-input", placeholder: "Введите пароль" %>
    </div>

    <div class="center-form">
      <%= submit_tag "Помычали!", class: "btn btn-new new-game-btn" %>
    </div>
  <% end %>
</div>

<div class="auth-footer">
  <span class="auth-text">Нет аккаунта?</span>
  <%= link_to "Зарегистрироваться", signup_path, class: "auth-button" %>
</div>

<div class="auth-footer">
  <span class="auth-text">Не удаётся войти?</span>
  <%= link_to "Восстановить пароль", new_password_reset_path, class: "auth-button" %>
</div>