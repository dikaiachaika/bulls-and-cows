<h1>Вход</h1>

<div class="game-info">
  <%= form_with url: login_path do |f| %>
    <div class="form-group">
      <%= label_tag :name, "Имя" %>
      <%= text_field_tag :name, nil, maxlength: 20, class: "guess-input", placeholder: "вы кто" %>
    </div>

    <div class="form-group">
      <%= label_tag :password, "Пароль" %>
      <%= password_field_tag :password, nil, maxlength: 20, class: "guess-input", placeholder: "точно?" %>
    </div>

    <div class="center-form">
      <%= submit_tag "Помычали!", class: "btn btn-new new-game-btn" %>
    </div>
  <% end %>
</div>

<p class="games-count">
  Нет аккаунта? Тогда советую <%= link_to "Зарегистрироваться", signup_path, class: "play-btn" %>
</p>