<h1>Смена пароля</h1>

<div class="game-info">
  <%= form_with model: @user, url: password_reset_path(@user), method: :patch, local: true do |f| %>
    
    <div class="auth-footer">
      <p>Секретный вопрос: <strong><%= @user.security_question %></strong></p>
    </div>

    <div class="form-group">
      <%= label_tag :security_answer, "Ваш ответ" %>
      <%= text_field_tag :security_answer, nil, class: "guess-input input-reset-password", placeholder: "Введите ответ на секретный вопрос" %>
    </div>

    <div class="form-group">
      <%= label_tag :password, "Новый пароль" %>
      <%= password_field_tag "user[password]", nil, class: "guess-input", placeholder: "Введите новый пароль" %>
    </div>

    <div class="form-group">
      <%= label_tag :password_confirmation, "Подтверждение" %>
      <%= password_field_tag "user[password_confirmation]", nil, class: "guess-input", placeholder: "Повторите пароль" %>
    </div>

    <div class="center-form">
      <%= submit_tag "Сменить пароль", class: "btn btn-new new-game-btn" %>
    </div>

  <% end %>
</div>